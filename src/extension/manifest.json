{
  "manifest_version": 3,
  "name": "Bilibili Accelerator",
  "version": "0.2.0",
  "description": "Speeds up slow Bilibili playback by rewriting weak CDN/PCDN URLs before buffering.",
  "icons": {},
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "Bilibili Accelerator",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.bilibili.com/*",
        "https://*.bilibili.tv/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "host_permissions": [
    "https://*.bilibili.com/*",
    "https://*.bilibili.tv/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "bili-accelerator.page.js"
      ],
      "matches": [
        "https://*.bilibili.com/*",
        "https://*.bilibili.tv/*"
      ]
    }
  ]
}
